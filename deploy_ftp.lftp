open -u "$FTP_USER","$FTP_PASS" "ftp://$FTP_HOST"
set ssl:verify-certificate no
# Sincronizar la carpeta pública (en Plesk debes apuntar el Document Root a /public)
mirror -R public/ public/
# Sincronizar el backend
mirror -R backend/ backend/
# Subir archivos sueltos necesarios para Node.js (App.js incluido)
put app.js
put package.json
put package-lock.json
put .env.production -o .env
quit
